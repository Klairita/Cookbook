          {
            "id": 8,
            "name": "Vinegar",
            "amount": 30,
            "unit": "ml"
          },
          {
            "id": 9,
            "name": "Sugar",
            "amount": 20,
            "unit": "g"
          },
          {
            "id": 10,
            "name": "Bay leaves",
            "amount": 3,
            "unit": "pcs"
          }
        ]
      }
    ],
    "steps": [
      {
        "id": 1,
        "text": "Lard the beef with thin strips of carrot and celery root. Season generously with salt and pepper. Marinate in the fridge for at least 2 hours, ideally overnight.",
        "timerMinutes": null
      },
      {
        "id": 2,
        "text": "Sear the beef in butter over high heat on all sides until deeply golden brown. Don't rush this.",
        "timerMinutes": 10
      },
      {
        "id": 3,
        "text": "Add diced onion, carrots, celery root, bay leaves and peppercorns. Pour in the broth.",
        "timerMinutes": null
      },
      {
        "id": 4,
        "text": "Cover and braise in oven at 160°C, turning occasionally.",
        "timerMinutes": 120
      },
      {
        "id": 5,
        "text": "Remove beef and let it rest. Strain braising liquid, add cream, vinegar and sugar. Simmer to reduce.",
        "timerMinutes": 15
      },
      {
        "id": 6,
        "text": "Blend sauce until smooth. Adjust with salt, sugar and vinegar. Slice beef and serve with sauce and bread dumplings.",
        "timerMinutes": null
      }
    ]
